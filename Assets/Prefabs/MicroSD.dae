          <area_sizez sid="area_sizez" type="float">1</area_sizez>
        </technique>
      </extra>
    </light>
  </library_lights>
  <library_effects>
    <effect id="plane-effect">
      <profile_COMMON>
        <newparam sid="Plane_png-surface">
          <surface type="2D">
            <init_from>Plane_png</init_from>
          </surface>
        </newparam>
        <newparam sid="Plane_png-sampler">
          <sampler2D>
            <source>Plane_png-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="Plane_png-sampler" texcoord="UVMap"/>
            </diffuse>
            <reflectivity>
              <float sid="specular">0.3772727</float>
            </reflectivity>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="backcover-effect">
      <profile_COMMON>
        <newparam sid="backcover_png-surface">
          <surface type="2D">
            <init_from>backcover_png</init_from>
          </surface>
        </newparam>
        <newparam sid="backcover_png-sampler">
          <sampler2D>
            <source>backcover_png-surface</source>
