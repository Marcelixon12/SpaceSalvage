        <technique sid="common">
          <lambert>
            <emission>
              <color sid="emission">0 0 0 1</color>
            </emission>
            <diffuse>
              <texture texture="backcover_png-sampler" texcoord="UVMap"/>
            </diffuse>
            <index_of_refraction>
              <float sid="ior">1.45</float>
            </index_of_refraction>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="sdcard-effect">
      <profile_COMMON>
        <newparam sid="sdcard_png-surface">
          <surface type="2D">
            <init_from>sdcard_png</init_from>
          </surface>
        </newparam>
